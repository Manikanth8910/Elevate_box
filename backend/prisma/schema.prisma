generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// ENUMS
// ==========================================
enum DocumentStatus {
  DRAFT
  SUBMITTED
  ASSIGNED
  UNDER_REVIEW
  CHANGES_REQUESTED
  RESUBMITTED
  REVIEWER_APPROVED
  REJECTED
  PUBLISHED
  ARCHIVED
}

enum DocumentPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Role {
  VIEWER
  AUTHOR
  REVIEWER
  ADMIN
}

enum EventType {
  INFO
  WARNING
  CRITICAL
}

// ==========================================
// CORE ENTITIES
// ==========================================

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  passwordHash   String
  firstName      String
  lastName       String
  role           Role      @default(VIEWER)
  version        Int       @default(1)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  documents      Document[]        @relation("DocumentAuthor")
  reviewedDocs   Document[]        @relation("DocumentReviewer")
  editedDocs     Document[]        @relation("DocumentEditor")
  sessions       Session[]
  comments       Comment[]
  notifications  Notification[]
  auditLogs      AuditLog[]        @relation("AuditActor")
  workflows      WorkflowHistory[] @relation("WorkflowActor")
  activityFeed   ActivityFeed[]    @relation("ActivityActor")
  reviewAssignments ReviewAssignment[] @relation("ReviewerAssignments")
  adminAssignments  ReviewAssignment[] @relation("AdminAssignments")
  messages       DiscussionMessage[]
  decisions      ReviewDecision[]

  @@index([email])
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  expiresAt    DateTime
  version      Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Document {
  id             String         @id @default(uuid())
  title          String
  body           String         @db.Text
  status         DocumentStatus @default(DRAFT)
  authorId       String
  reviewerId     String?
  version        Int            @default(1) // Optimistic Lock
  wordCount      Int            @default(0)
  readingTime    Int            @default(0)
  lastEditedBy   String?
  lastEditedAt   DateTime?
  submittedAt    DateTime?
  approvedAt     DateTime?
  publishedAt    DateTime?
  archivedAt     DateTime?
  reviewDeadline DateTime?
  priority       DocumentPriority @default(MEDIUM)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  softDeleteFlag Boolean        @default(false)
  deletedAt      DateTime?

  author         User              @relation("DocumentAuthor", fields: [authorId], references: [id])
  reviewer       User?             @relation("DocumentReviewer", fields: [reviewerId], references: [id])
  editor         User?             @relation("DocumentEditor", fields: [lastEditedBy], references: [id])
  versions       DocumentVersion[]
  workflowHistory WorkflowHistory[]
  assignments    ReviewAssignment[]
  thread         DiscussionThread?
  attachments    DocumentAttachment[]
  decisions      ReviewDecision[]
  
  @@index([authorId])
  @@index([status])
  @@index([softDeleteFlag])
}

model DocumentVersion {
  id            String   @id @default(uuid())
  documentId    String
  versionNumber Int
  content       String   @db.Text
  version       Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  document      Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  comments      Comment[]

  @@unique([documentId, versionNumber])
  @@index([documentId])
}

enum CommentType {
  GENERAL
  SUGGESTION
  INLINE
  SUMMARY
}

enum CommentSeverity {
  INFO
  WARNING
  BLOCKER
}

enum ResolutionStatus {
  OPEN
  RESOLVED
  WONT_FIX
}

model Comment {
  id               String          @id @default(uuid())
  versionId        String
  authorId         String
  text             String          @db.Text
  type             CommentType     @default(GENERAL)
  severity         CommentSeverity @default(INFO)
  resolutionStatus ResolutionStatus @default(OPEN)
  version          Int             @default(1)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  deletedAt        DateTime?

  versionRef       DocumentVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  author           User            @relation(fields: [authorId], references: [id])
  decisionId       String?
  decision         ReviewDecision? @relation(fields: [decisionId], references: [id], onDelete: SetNull)

  @@index([versionId])
  @@index([authorId])
}

// ==========================================
// ENTERPRISE WORKFLOW MODELS
// ==========================================

model ReviewAssignment {
  id          String   @id @default(uuid())
  documentId  String
  reviewerId  String
  adminId     String
  priority    DocumentPriority @default(MEDIUM)
  deadline    DateTime
  status      String   @default("ACTIVE") // ACTIVE, COMPLETED, CANCELLED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  reviewer    User     @relation("ReviewerAssignments", fields: [reviewerId], references: [id])
  admin       User     @relation("AdminAssignments", fields: [adminId], references: [id])

  @@index([documentId])
  @@index([reviewerId])
}

model DiscussionThread {
  id          String   @id @default(uuid())
  documentId  String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  messages    DiscussionMessage[]

  @@index([documentId])
}

model DiscussionMessage {
  id            String   @id @default(uuid())
  threadId      String
  authorId      String
  text          String   @db.Text
  versionNumber Int
  createdAt     DateTime @default(now())

  thread        DiscussionThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author        User             @relation(fields: [authorId], references: [id])

  @@index([threadId])
  @@index([authorId])
}

model NotificationPreference {
  id                 String  @id @default(uuid())
  userId             String  @unique
  emailNotifications Boolean @default(true)
  inAppNotifications Boolean @default(true)
  
  @@index([userId])
}

model ReviewDecision {
  id          String   @id @default(uuid())
  documentId  String
  reviewerId  String
  decision    String   // APPROVE, REJECT, REQUEST_CHANGES
  version     Int
  createdAt   DateTime @default(now())

  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  reviewer    User     @relation(fields: [reviewerId], references: [id])
  comments    Comment[]

  @@index([documentId])
  @@index([reviewerId])
}

model DocumentAttachment {
  id          String   @id @default(uuid())
  documentId  String
  filename    String
  url         String
  size        Int
  mimeType    String
  uploadedById String
  createdAt   DateTime @default(now())

  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

// ==========================================
// WORKFLOW & AUDIT ENGINES
// ==========================================

model WorkflowHistory {
  id          String         @id @default(uuid())
  documentId  String
  actorId     String
  fromStatus  DocumentStatus
  toStatus    DocumentStatus
  reason      String?
  version     Int            @default(1)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  actor       User     @relation("WorkflowActor", fields: [actorId], references: [id])

  @@index([documentId])
  @@index([actorId])
}

model AuditLog {
  id          String   @id @default(uuid())
  actorId     String?
  action      String
  entityType  String
  entityId    String
  oldState    Json?
  newState    Json?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  actor       User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
}

model ActivityFeed {
  id          String   @id @default(uuid())
  actorId     String
  action      String
  entityType  String
  entityId    String
  summary     String
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  actor       User     @relation("ActivityActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  title       String
  message     String
  type        EventType @default(INFO)
  isRead      Boolean  @default(false)
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

// ==========================================
// SYSTEM & CONFIGURATION
// ==========================================

model AnalyticsSnapshots {
  id          String   @id @default(uuid())
  metricName  String
  metricValue Float
  dimensions  Json?
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([metricName])
  @@index([createdAt])
}

model SystemSettings {
  id          String   @id @default(uuid())
  key         String   @unique
  value       Json
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
}

model WorkflowRules {
  id          String         @id @default(uuid())
  fromStatus  DocumentStatus
  toStatus    DocumentStatus
  conditions  Json
  version     Int            @default(1)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?

  @@unique([fromStatus, toStatus])
}
